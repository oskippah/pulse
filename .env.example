# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Finnhub (financial news) ─────────────────────────────────────────────────
# Free tier at https://finnhub.io → Sign up → Dashboard → API Key
VITE_FINNHUB_API_KEY=your-finnhub-api-key-here

# ─── football-data.org (FIFA World Cup) ───────────────────────────────────────
# Free tier at https://www.football-data.org → Register → My Account → API Token
VITE_FOOTBALL_API_KEY=your-football-data-api-key-here
